# ── Site ─────────────────────────────────────────────────────────────────────
# Canonical origin. Defaults to https://seotecnico.dev.br when unset.
NEXT_PUBLIC_DOMAIN=

# ── Indexing fail-safe ───────────────────────────────────────────────────────
# The site sends noindex/nofollow and "Disallow: /" unless this is exactly
# "true". Set it only in the real production environment on Vercel.
SITE_INDEXABLE=

# ── Analytics ────────────────────────────────────────────────────────────────
# GTM web container id (GTM-XXXXXXX). GTM only mounts when set.
NEXT_PUBLIC_GTM_ID=

# ── Google Search Console ────────────────────────────────────────────────────
# HTML-tag verification token (not needed if the domain property is verified
# via DNS, which is the plan — kept for flexibility).
GOOGLE_SITE_VERIFICATION=
